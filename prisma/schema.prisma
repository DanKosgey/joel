generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentType {
  PASSPORT
  ID_CARD
}

enum SignalDirection {
  BUY
  SELL
}

enum SignalStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(CLIENT)
  kycStatus    KycStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  mt5Accounts    Mt5Account[]
  kycSubmission  KycSubmission?
  signals        Signal[]        @relation("BroadcastedByAdmin")

  @@index([email])
}

model Mt5Account {
  id            String   @id @default(uuid())
  userId        String
  brokerName    String
  accountNumber String
  serverName    String
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Relations
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades         Trade[]
  dailySnapshots DailyEquitySnapshot[]
  riskBreaches   RiskBreach[]
  executions     SignalExecutionLog[]

  @@index([userId])
}

model KycSubmission {
  id               String       @id @default(uuid())
  userId           String       @unique
  fullName         String
  dateOfBirth      DateTime
  nationality      String
  documentType     DocumentType
  documentFrontUrl String
  documentBackUrl  String
  selfieUrl        String
  submittedAt      DateTime     @default(now())
  reviewedAt       DateTime?
  reviewNotes      String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Signal {
  id            String        @id @default(uuid())
  adminId       String                                  // Admin User.id
  instrument    String        @default("XAUUSD")
  direction     SignalDirection
  entryPrice    Float
  stopLoss      Float
  takeProfit    Float
  status        SignalStatus  @default(ACTIVE)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?

  // Relations
  admin      User                 @relation("BroadcastedByAdmin", fields: [adminId], references: [id])
  trades     Trade[]
  executions SignalExecutionLog[]

  @@index([adminId])
  @@index([status])
  @@index([openedAt])
}

model Trade {
  id             String    @id @default(uuid())
  mt5AccountId   String
  ticket         String    @unique // MT5 ticket number
  instrument     String    @default("XAUUSD")
  direction      String    // BUY or SELL
  lots           Float
  entryPrice     Float
  exitPrice      Float?
  profit         Float
  commission     Float     @default(0.0)
  swap           Float     @default(0.0)
  openedAt       DateTime
  closedAt       DateTime?
  signalId       String?   // Links to broadcasted system signal if copy-traded
  createdAt      DateTime  @default(now())

  // Relations
  mt5Account     Mt5Account @relation(fields: [mt5AccountId], references: [id], onDelete: Cascade)
  signal         Signal?    @relation(fields: [signalId], references: [id])

  @@index([mt5AccountId])
  @@index([closedAt])
}

model DailyEquitySnapshot {
  id             String    @id @default(uuid())
  mt5AccountId   String
  date           DateTime  @db.Date
  balance        Float
  equity         Float
  margin         Float     @default(0.0)
  freeMargin     Float     @default(0.0)
  drawdown       Float     @default(0.0) // Peak-to-trough drawdown percentage on this day
  createdAt      DateTime  @default(now())

  // Relations
  mt5Account     Mt5Account @relation(fields: [mt5AccountId], references: [id], onDelete: Cascade)

  @@unique([mt5AccountId, date])
  @@index([date])
}

model RiskBreach {
  id             String    @id @default(uuid())
  mt5AccountId   String
  type           String    // "MAX_DAILY_DRAWDOWN" | "MAX_TOTAL_DRAWDOWN" | "UNAUTHORIZED_SYMBOL" | "MAX_LOTS_EXCEEDED"
  description    String
  breachedValue  Float
  limitValue     Float
  status         String    @default("ACTIVE") // "ACTIVE" | "RESOLVED" | "WAIVED"
  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?
  reviewNotes    String?

  // Relations
  mt5Account     Mt5Account @relation(fields: [mt5AccountId], references: [id], onDelete: Cascade)

  @@index([mt5AccountId])
  @@index([status])
}

model SignalExecutionLog {
  id             String    @id @default(uuid())
  signalId       String
  mt5AccountId   String
  status         String    // "PENDING" | "EXECUTED" | "FAILED"
  executionPrice Float?
  errorMessage   String?
  executedAt     DateTime?
  
  // Relations
  signal         Signal     @relation(fields: [signalId], references: [id], onDelete: Cascade)
  mt5Account     Mt5Account @relation(fields: [mt5AccountId], references: [id], onDelete: Cascade)

  @@unique([signalId, mt5AccountId])
}

model CompanyGrowthSnapshot {
  id                   String   @id @default(uuid())
  date                 DateTime @unique @db.Date
  totalAum             Float    // Sum of all client equities
  activeClients        Int      // Verified users with linked mt5 accounts
  totalDeposit         Float    // Accumulation of deposits
  totalWithdrawal      Float    // Accumulation of withdrawals
  netRevenue           Float    // Calculated from commission/performance fees
  averageClientWinRate Float
  averageDrawdown      Float
  createdAt            DateTime @default(now())
}

