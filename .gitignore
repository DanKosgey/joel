# ==============================
# Dependencies
# ==============================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==============================
# Next.js Build Output
# ==============================
/.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# ==============================
# Environment Variables (SECRETS)
# ==============================
.env
.env.*
!.env.example
!.env.local.example

# ==============================
# IDE & Editor
# ==============================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ==============================
# OS Generated Files
# ==============================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==============================
# Testing & Coverage
# ==============================
/coverage
*.lcov
.nyc_output

# ==============================
# Debug Logs
# ==============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*

# ==============================
# Package Manager Lock Files
# (keep only the one you use)
# ==============================
# package-lock.json
# yarn.lock

# ==============================
# Certificates & Keys
# ==============================
*.pem
*.key
*.cert

# ==============================
# Vercel
# ==============================
.vercel

# ==============================
# Prisma
# ==============================
prisma/*.db
prisma/*.db-journal

